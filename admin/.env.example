# Backend API base URL
VITE_API_URL=/api/v1
VITE_API_URL_PROXY=http://localhost:5000

# Public admin URL
VITE_ADMIN_URL=http://localhost:3100

# Public site URL (for "view live" links)
VITE_PUBLIC_SITE_URL=http://localhost:3000

# Cloudinary (client-side unsigned upload preset — used only for admin media library)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=metlifedm_admin

# Feature flags
VITE_ENABLE_REALTIME=true
