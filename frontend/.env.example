# API base URL (production: full URL, dev: leave blank to use Vite proxy)
VITE_API_URL=/api/v1
VITE_API_URL_PROXY=http://localhost:5000

# Public site URL
VITE_SITE_URL=http://localhost:3000

# Stripe publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Analytics
VITE_GA4_ID=
VITE_META_PIXEL_ID=

# Feature flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_ANNOUNCEMENT=true
