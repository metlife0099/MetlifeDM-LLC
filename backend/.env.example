# ============================================================
# MetlifeDM LLC — Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ------------------ Server ------------------
NODE_ENV=development
PORT=5000
API_VERSION=v1
API_PREFIX=/api

# ------------------ URLs ------------------
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
SERVER_URL=http://localhost:5000

# ------------------ MongoDB ------------------
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/metlifedm?retryWrites=true&w=majority
MONGO_DB_NAME=metlifedm

# ------------------ Redis (caching + rate limiting + sessions) ------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL_DEFAULT=3600

# ------------------ JWT ------------------
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_REFRESH_EXPIRES=7d
JWT_EMAIL_VERIFY_SECRET=change_me_verify
JWT_EMAIL_VERIFY_EXPIRES=1d
JWT_PASSWORD_RESET_SECRET=change_me_reset
JWT_PASSWORD_RESET_EXPIRES=15m

# ------------------ Cookies ------------------
COOKIE_SECRET=change_me_cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ------------------ Bcrypt ------------------
BCRYPT_SALT_ROUNDS=12

# ------------------ Stripe ------------------
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_CURRENCY=usd

# ------------------ Cloudinary ------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=metlifedm

# ------------------ Brevo (Sendinblue) SMTP ------------------
BREVO_API_KEY=your_brevo_api_key
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_login
BREVO_SMTP_PASS=your_brevo_smtp_key
MAIL_FROM_NAME=MetlifeDM LLC
MAIL_FROM_ADDRESS=hello@metlifedm.com
MAIL_REPLY_TO=support@metlifedm.com

# ------------------ Google Gemini (AI Chatbot) ------------------
# Free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=800
GEMINI_TEMPERATURE=0.7
CHATBOT_CONFIDENCE_THRESHOLD=0.6

# ------------------ Rate Limiting ------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# ------------------ Logging ------------------
LOG_LEVEL=info
LOG_DIR=logs

# ------------------ Security ------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
TRUST_PROXY=1

# ------------------ Admin Seed ------------------
SEED_SUPER_ADMIN_EMAIL=admin@metlifedm.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMeStrong!123
SEED_SUPER_ADMIN_NAME=Super Admin

# ------------------ Analytics ------------------
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
GTM_ID=

# ------------------ Feature Flags ------------------
ENABLE_2FA=true
ENABLE_SWAGGER=true
ENABLE_REDIS_CACHE=true
